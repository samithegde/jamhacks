CLARITY_PROXY_URL=http://127.0.0.1:8787
GEMINI_API_KEY=key
# Optional: override default model (gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Remote RAG — Context7 (library/framework docs) + web search
# Get Context7 key: https://context7.com
CONTEXT7_API_KEY=
# Web search via Tavily (default) — https://tavily.com
TAVILY_API_KEY=
# Or use Serper instead: RAG_WEB_PROVIDER=serper and SERPER_API_KEY=
# RAG_WEB_PROVIDER=tavily
# SERPER_API_KEY=
# RAG_ROUTER_MODEL=gemini-2.0-flash-lite
# RAG_ENABLED=true

# Dev: set to false to use local Ollama (text-only) instead of Gemini (default: true)
# USE_GEMINI_MODEL=false
# OLLAMA_MODEL=llama3.3
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# Groq — required for interactive tutor widget implementation (Gemini plans, Groq builds)
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_REQUEST_TIMEOUT_MS=120000
# Chat telemetry (default on). Events are logged to console and data/telemetry/chat-events.jsonl
# TELEMETRY_ENABLED=true
# Detailed AI activity log (intent, RAG, model response, localization, actions)
# CHAT_ACTIVITY_LOG=true
# Optional: legacy Set-of-Mark pre-discovery (default off; pipeline uses Gemini bbox + Moondream)
SOM_ENABLED=false

# Moondream point refinement for crop localization (default on unless set to false)
# Hybrid: tries local endpoint first, then Cloud API when MOONDREAM_API_KEY is set.
MOONDREAM_ENABLED=true
MOONDREAM_ENDPOINT=http://localhost:2020/v1
MOONDREAM_API_KEY=
# Local: pip install moondream-station && moondream-station
# Cloud: https://moondream.ai/c/cloud/api-keys

ELEVENLABS_API_KEY=key
# Optional: override default ElevenLabs voice/model
# ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
# ELEVENLABS_MODEL=eleven_multilingual_v2

# Required for chat history persistence (full Atlas connection string)
# ${MONGO_DB_PASSWORD} and other ${VAR} refs are expanded at runtime
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
# Or use split credentials (used as fallback when MONGODB_URI is absent):
# MONGO_DB_USER=your_db_user
# MONGO_DB_PASSWORD=your_db_password
# MONGODB_CLUSTER_HOST=cluster.mongodb.net
# Optional: override default MongoDB database name (clarity)
# MONGODB_DB=clarity
