{
  "name": "clarity",
  "version": "1.0.0",
  "description": "Clarity overlay desktop app",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "worker:secret": "wrangler secret put GROQ_API_KEY",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:dir": "electron-builder --dir"
  },
  "build": {
    "appId": "com.clarity.app",
    "productName": "Clarity",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "src/**/*"
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250613.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.3",
    "wrangler": "^4.100.0"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "dompurify": "^3.4.10",
    "marked": "^18.0.5"
  }
}
