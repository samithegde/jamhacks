CLARITY_PROXY_URL=http://127.0.0.1:8787
GEMINI_API_KEY=key
# Optional: override default model (gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

ELEVENLABS_API_KEY=key
# Optional: override default ElevenLabs voice/model
# ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
# ELEVENLABS_MODEL=eleven_multilingual_v2

# Required for chat history persistence (full Atlas connection string)
# ${MONGO_DB_PASSWORD} and other ${VAR} refs are expanded at runtime
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
# Or use split credentials (used as fallback when MONGODB_URI is absent):
# MONGO_DB_USER=your_db_user
# MONGO_DB_PASSWORD=your_db_password
# MONGODB_CLUSTER_HOST=cluster.mongodb.net
# Optional: override default MongoDB database name (clarity)
# MONGODB_DB=clarity
